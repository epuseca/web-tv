<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Quản lý Slideshow</title>
    <!-- Ant Design CSS từ CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/antd/5.10.0/antd.min.css">
    <!-- Font Awesome cho icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f5f5f5;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .header {
            background: white;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .header h1 {
            color: #1890ff;
            font-size: 28px;
            margin-bottom: 10px;
        }

        .header p {
            color: #666;
            font-size: 14px;
        }

        .content {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        /* FORM SECTION */
        .form-section {
            background: white;
            padding: 24px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .form-section h2 {
            color: #1890ff;
            font-size: 18px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }

        .form-section h2 i {
            margin-right: 10px;
            font-size: 20px;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-weight: 500;
            margin-bottom: 8px;
            color: #262626;
            font-size: 14px;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #d9d9d9;
            border-radius: 4px;
            font-size: 14px;
            font-family: inherit;
            transition: all 0.3s;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: #1890ff;
            box-shadow: 0 0 0 2px rgba(24, 144, 255, 0.2);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 80px;
        }

        .image-preview {
            width: 100%;
            max-height: 150px;
            object-fit: cover;
            border-radius: 4px;
            margin-top: 8px;
            border: 1px solid #d9d9d9;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            margin-bottom: 16px;
        }

        .checkbox-group input[type="checkbox"] {
            width: 16px;
            height: 16px;
            margin-right: 8px;
            cursor: pointer;
        }

        .checkbox-group label {
            margin: 0;
            cursor: pointer;
        }

        .button-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 24px;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary {
            background: #1890ff;
            color: white;
        }

        .btn-primary:hover {
            background: #40a9ff;
            box-shadow: 0 2px 8px rgba(24, 144, 255, 0.3);
        }

        .btn-secondary {
            background: #f5f5f5;
            color: #262626;
            border: 1px solid #d9d9d9;
        }

        .btn-secondary:hover {
            border-color: #1890ff;
            color: #1890ff;
        }

        /* TABLE SECTION */
        .table-section {
            background: white;
            padding: 24px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .table-section h2 {
            color: #1890ff;
            font-size: 18px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }

        .table-section h2 i {
            margin-right: 10px;
            font-size: 20px;
        }

        .no-data {
            text-align: center;
            padding: 40px;
            color: #999;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
        }

        .table thead {
            background: #fafafa;
            border-bottom: 2px solid #f0f0f0;
        }

        .table th {
            padding: 12px;
            text-align: left;
            font-weight: 600;
            color: #262626;
            font-size: 14px;
        }

        .table td {
            padding: 12px;
            border-bottom: 1px solid #f0f0f0;
            font-size: 14px;
        }

        .table tbody tr:hover {
            background: #f9f9f9;
        }

        .image-thumbnail {
            width: 80px;
            height: 60px;
            object-fit: cover;
            border-radius: 4px;
            border: 1px solid #d9d9d9;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
        }

        .status-active {
            background: #f6ffed;
            color: #52c41a;
            border: 1px solid #b7eb8f;
        }

        .status-inactive {
            background: #fff1f0;
            color: #ff4d4f;
            border: 1px solid #ffccc7;
        }

        .action-buttons {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .btn-sm {
            padding: 6px 12px;
            border: none;
            border-radius: 4px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .btn-edit {
            background: #1890ff;
            color: white;
        }

        .btn-edit:hover {
            background: #40a9ff;
        }

        .btn-toggle {
            background: #faad14;
            color: white;
        }

        .btn-toggle:hover {
            background: #fbc53d;
        }

        .btn-delete {
            background: #ff4d4f;
            color: white;
        }

        .btn-delete:hover {
            background: #ff7875;
        }

        /* MODAL / MODAL OVERLAY */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.45);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: white;
            padding: 24px;
            border-radius: 8px;
            width: 90%;
            max-width: 500px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 3px 12px rgba(0, 0, 0, 0.15);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 1px solid #f0f0f0;
            padding-bottom: 16px;
        }

        .modal-header h3 {
            color: #1890ff;
            font-size: 16px;
            margin: 0;
        }

        .close-btn {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            color: #999;
            transition: color 0.3s;
        }

        .close-btn:hover {
            color: #262626;
        }

        .modal-body {
            margin-bottom: 20px;
        }

        .modal-footer {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        /* NOTIFICATIONS */
        .alert {
            padding: 12px 16px;
            border-radius: 4px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideIn 0.3s ease-out;
        }

        .alert-success {
            background: #f6ffed;
            border: 1px solid #b7eb8f;
            color: #52c41a;
        }

        .alert-error {
            background: #fff1f0;
            border: 1px solid #ffccc7;
            color: #ff4d4f;
        }

        .alert-info {
            background: #e6f7ff;
            border: 1px solid #91d5ff;
            color: #0050b3;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .text-muted {
            color: #999;
            font-size: 13px;
        }

        @media (max-width: 768px) {
            .content {
                grid-template-columns: 1fr;
            }

            .button-group {
                grid-template-columns: 1fr;
            }

            .action-buttons {
                flex-direction: column;
            }

            .table {
                font-size: 12px;
            }

            .table th,
            .table td {
                padding: 8px;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <!-- HEADER -->
        <div class="header">
            <h1><i class="fas fa-images"></i> Quản lý Slideshow Hình ảnh</h1>
            <p>Thêm, chỉnh sửa, xóa và quản lý các hình ảnh để trình chiếu trên TV</p>
        </div>

        <!-- NOTIFICATIONS -->
        <div id="alertContainer"></div>

        <!-- MAIN CONTENT -->
        <div class="content">
            <!-- LEFT: FORM SECTION -->
            <div class="form-section">
                <h2><i class="fas fa-plus-circle"></i> Thêm Hình ảnh Mới</h2>

                <form id="imageForm">
                    <div class="form-group">
                        <label for="name">Tên Hình ảnh *</label>
                        <input type="text" id="name" name="name" required placeholder="Nhập tên hình ảnh">
                    </div>

                    <div class="form-group">
                        <label for="description">Mô Tả</label>
                        <textarea id="description" name="description"
                            placeholder="Nhập mô tả chi tiết về hình ảnh"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="imageFile">Chọn Hình ảnh *</label>
                        <input type="file" id="imageFile" name="imageFile" accept="image/*" required>
                        <img id="previewImage" class="image-preview" style="display: none;">
                        <p class="text-muted">Định dạng hỗ trợ: JPG, PNG, GIF, WebP. Tối đa 50MB</p>
                    </div>

                    <div class="checkbox-group">
                        <input type="checkbox" id="isActive" name="isActive" checked>
                        <label for="isActive">Kích hoạt hình ảnh này</label>
                    </div>

                    <div class="button-group">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Thêm Hình ảnh
                        </button>
                        <button type="reset" class="btn btn-secondary">
                            <i class="fas fa-redo"></i> Làm mới
                        </button>
                    </div>
                </form>
            </div>

            <!-- RIGHT: TABLE SECTION -->
            <div class="table-section">
                <h2><i class="fas fa-list"></i> Danh Sách Hình ảnh</h2>

                <div id="tableContainer">
                    <div class="no-data">
                        <p><i class="fas fa-inbox"
                                style="font-size: 32px; color: #d9d9d9; margin-bottom: 10px; display: block;"></i></p>
                        <p>Chưa có hình ảnh nào. Hãy thêm hình ảnh mới!</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- EDIT MODAL -->
    <div id="editModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Chỉnh Sửa Hình ảnh</h3>
                <button class="close-btn" onclick="closeEditModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="editForm">
                    <input type="hidden" id="editImageId">

                    <div class="form-group">
                        <label for="editName">Tên Hình ảnh *</label>
                        <input type="text" id="editName" name="editName" required>
                    </div>

                    <div class="form-group">
                        <label for="editDescription">Mô Tả</label>
                        <textarea id="editDescription" name="editDescription"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="editImageFile">Cập nhật Hình ảnh</label>
                        <input type="file" id="editImageFile" name="editImageFile" accept="image/*">
                        <img id="editPreviewImage" class="image-preview" style="margin-top: 10px;">
                        <p class="text-muted">Để trống nếu không muốn thay đổi hình ảnh</p>
                    </div>

                    <div class="checkbox-group">
                        <input type="checkbox" id="editIsActive" name="editIsActive">
                        <label for="editIsActive">Kích hoạt hình ảnh này</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeEditModal()">
                    <i class="fas fa-times"></i> Hủy
                </button>
                <button class="btn btn-primary" onclick="saveEditImage()">
                    <i class="fas fa-save"></i> Lưu Thay Đổi
                </button>
            </div>
        </div>
    </div>

    <script>
        // ==================== HELPER FUNCTIONS ====================

        // Hiển thị thông báo
        function showAlert(message, type = 'success') {
            const alertContainer = document.getElementById('alertContainer');
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type}`;
            alertDiv.innerHTML = `
                <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle'}"></i>
                <span>${message}</span>
            `;
            alertContainer.appendChild(alertDiv);

            setTimeout(() => {
                alertDiv.style.animation = 'slideOut 0.3s ease-out';
                setTimeout(() => alertDiv.remove(), 300);
            }, 3000);
        }

        // Chuyển đổi file image thành Base64
        function fileToBase64(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = () => resolve(reader.result);
                reader.onerror = error => reject(error);
                reader.readAsDataURL(file);
            });
        }

        // ==================== IMAGE UPLOAD & PREVIEW ====================

        // Preview ảnh khi chọn
        document.getElementById('imageFile')?.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (file) {
                const base64 = await fileToBase64(file);
                const preview = document.getElementById('previewImage');
                preview.src = base64;
                preview.style.display = 'block';
            }
        });

        document.getElementById('editImageFile')?.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (file) {
                const base64 = await fileToBase64(file);
                const preview = document.getElementById('editPreviewImage');
                preview.src = base64;
            }
        });

        // ==================== FORM SUBMISSION ====================

        // Thêm hình ảnh mới
        document.getElementById('imageForm')?.addEventListener('submit', async (e) => {
            e.preventDefault();

            const name = document.getElementById('name').value;
            const description = document.getElementById('description').value;
            const imageFile = document.getElementById('imageFile').files[0];
            const isActive = document.getElementById('isActive').checked;

            if (!imageFile) {
                showAlert('Vui lòng chọn hình ảnh', 'error');
                return;
            }

            try {
                const imageData = await fileToBase64(imageFile);

                const response = await fetch('/api/images', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        name,
                        description,
                        imageData,
                        isActive
                    })
                });

                if (response.ok) {
                    showAlert('Thêm hình ảnh thành công!', 'success');
                    document.getElementById('imageForm').reset();
                    document.getElementById('previewImage').style.display = 'none';
                    loadImages();
                } else {
                    showAlert('Lỗi khi thêm hình ảnh', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Lỗi: ' + error.message, 'error');
            }
        });

        // ==================== LOAD & DISPLAY IMAGES ====================

        async function loadImages() {
            try {
                const response = await fetch('/api/images');
                const images = await response.json();

                const tableContainer = document.getElementById('tableContainer');

                if (images.length === 0) {
                    tableContainer.innerHTML = `
                        <div class="no-data">
                            <p><i class="fas fa-inbox" style="font-size: 32px; color: #d9d9d9; margin-bottom: 10px; display: block;"></i></p>
                            <p>Chưa có hình ảnh nào. Hãy thêm hình ảnh mới!</p>
                        </div>
                    `;
                    return;
                }

                let tableHTML = `
                    <table class="table">
                        <thead>
                            <tr>
                                <th style="width: 10%;">Ảnh</th>
                                <th style="width: 20%;">Tên</th>
                                <th style="width: 30%;">Mô Tả</th>
                                <th style="width: 15%;">Trạng Thái</th>
                                <th style="width: 25%;">Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                `;

                images.forEach(image => {
                    const statusClass = image.isActive ? 'status-active' : 'status-inactive';
                    const statusText = image.isActive ? 'Hoạt động' : 'Tắt';

                    tableHTML += `
                        <tr>
                            <td>
                                <img src="${image.imageData}" alt="${image.name}" class="image-thumbnail">
                            </td>
                            <td><strong>${image.name}</strong></td>
                            <td>${image.description || '<em>Không có</em>'}</td>
                            <td>
                                <span class="status-badge ${statusClass}">${statusText}</span>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn-sm btn-edit" onclick="openEditModal('${image._id}')">
                                        <i class="fas fa-edit"></i> Sửa
                                    </button>
                                    <button class="btn-sm btn-toggle" onclick="toggleImageStatus('${image._id}')">
                                        <i class="fas fa-${image.isActive ? 'eye-slash' : 'eye'}"></i>
                                    </button>
                                    <button class="btn-sm btn-delete" onclick="deleteImage('${image._id}')">
                                        <i class="fas fa-trash"></i> Xóa
                                    </button>
                                </div>
                            </td>
                        </tr>
                    `;
                });

                tableHTML += `
                        </tbody>
                    </table>
                `;

                tableContainer.innerHTML = tableHTML;
            } catch (error) {
                console.error('Error loading images:', error);
                showAlert('Lỗi khi tải danh sách hình ảnh', 'error');
            }
        }

        // ==================== EDIT FUNCTIONS ====================

        async function openEditModal(imageId) {
            try {
                const response = await fetch(`/api/images/${imageId}`);
                const image = await response.json();

                document.getElementById('editImageId').value = image._id;
                document.getElementById('editName').value = image.name;
                document.getElementById('editDescription').value = image.description;
                document.getElementById('editIsActive').checked = image.isActive;
                document.getElementById('editPreviewImage').src = image.imageData;

                document.getElementById('editModal').classList.add('active');
            } catch (error) {
                console.error('Error opening edit modal:', error);
                showAlert('Lỗi khi mở form chỉnh sửa', 'error');
            }
        }

        function closeEditModal() {
            document.getElementById('editModal').classList.remove('active');
            document.getElementById('editForm').reset();
        }

        async function saveEditImage() {
            const imageId = document.getElementById('editImageId').value;
            const name = document.getElementById('editName').value;
            const description = document.getElementById('editDescription').value;
            const isActive = document.getElementById('editIsActive').checked;
            const imageFile = document.getElementById('editImageFile').files[0];

            let imageData = undefined;
            if (imageFile) {
                imageData = await fileToBase64(imageFile);
            }

            try {
                const payload = {
                    name,
                    description,
                    isActive
                };

                if (imageData) {
                    payload.imageData = imageData;
                }

                const response = await fetch(`/api/images/${imageId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    showAlert('Cập nhật hình ảnh thành công!', 'success');
                    closeEditModal();
                    loadImages();
                } else {
                    showAlert('Lỗi khi cập nhật hình ảnh', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Lỗi: ' + error.message, 'error');
            }
        }

        // ==================== DELETE & TOGGLE FUNCTIONS ====================

        async function deleteImage(imageId) {
            if (!confirm('Bạn có chắc chắn muốn xóa hình ảnh này?')) {
                return;
            }

            try {
                const response = await fetch(`/api/images/${imageId}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showAlert('Xóa hình ảnh thành công!', 'success');
                    loadImages();
                } else {
                    showAlert('Lỗi khi xóa hình ảnh', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Lỗi: ' + error.message, 'error');
            }
        }

        async function toggleImageStatus(imageId) {
            try {
                const response = await fetch(`/api/images/${imageId}/toggle`, {
                    method: 'PATCH'
                });

                if (response.ok) {
                    showAlert('Cập nhật trạng thái thành công!', 'success');
                    loadImages();
                } else {
                    showAlert('Lỗi khi cập nhật trạng thái', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Lỗi: ' + error.message, 'error');
            }
        }

        // ==================== INIT ====================

        // Tải danh sách hình ảnh khi trang load
        document.addEventListener('DOMContentLoaded', () => {
            loadImages();
            // Làm mới danh sách mỗi 5 giây
            setInterval(loadImages, 5000);
        });

        // Đóng modal khi click bên ngoài
        window.addEventListener('click', (e) => {
            const modal = document.getElementById('editModal');
            if (e.target === modal) {
                closeEditModal();
            }
        });
    </script>
</body>

</html>